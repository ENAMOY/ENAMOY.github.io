{
  "71123660": {
    "ref": "使徒行传 2:38",
    "versions": {
      "cuv": "彼得说：“你们各人要悔改，奉耶稣基督的名受洗，叫你们的罪得赦，就必领受所赐的圣灵。”",
      "ccb": "（当代译本待补充）",
      "esv": "(ESV translation to be added)"
    }
  },
  "d1c5cada": {
    "ref": "哥林多后书 7:10",
    "versions": {
      "cuv": "因为依着神的意思忧愁，就生出没有后悔的悔改来，以致得救；但世俗的忧愁是叫人死。",
      "ccb": "（当代译本待补充）",
      "esv": "(ESV translation to be added)"
    }
  },
  "19fbca56": {
    "ref": "诗篇 32:5",
    "versions": {
      "cuv": "我向你陈明我的罪，不隐瞒我的恶。\n我说：“我要向耶和华承认我的过犯”，你就赦免我的罪恶。",
      "ccb": "（当代译本待补充）",
      "esv": "(ESV translation to be added)"
    }
  },
  "08c611a6": {
    "ref": "使徒行传 26:20",
    "versions": {
      "cuv": "劝勉他们应当悔改归向神，行事与悔改的心相称。",
      "ccb": "（当代译本待补充）",
      "esv": "(ESV translation to be added)"
    }
  },
  "5da1e078": {
    "ref": "马太福音 3:8",
    "versions": {
      "cuv": "你们要结出果子来，与悔改的心相称。",
      "ccb": "（当代译本待补充）",
      "esv": "(ESV translation to be added)"
    }
  },
  "1ce23a87": {
    "ref": "约翰一书 1:9",
    "versions": {
      "cuv": "我们若认自己的罪，神是信实的，是公义的，必要赦免我们的罪，洗净我们一切的不义。",
      "ccb": "（当代译本待补充）",
      "esv": "(ESV translation to be added)"
    }
  },
  "7b355217": {
    "ref": "使徒行传 3:19,20",
    "versions": {
      "cuv": "所以，你们当悔改归正，使你们的罪得以涂抹。这样，那安舒的日子就必从主面前来到。",
      "ccb": "（当代译本待补充）",
      "esv": "(ESV translation to be added)"
    }
  },
  "c08df99c": {
    "ref": "马太福音 18:21-22",
    "versions": {
      "cuv": "那时彼得进前来，对耶稣说：“主阿，我弟兄得罪我，我当饶恕他几次呢？到七次可以吗？”\n耶稣说：“我对你说，不是到七次，乃是到七十个七次。”",
      "ccb": "（当代译本待补充）",
      "esv": "(ESV translation to be added)"
    }
  },
  "ccd89e4f": {
    "ref": "希伯来书 12:15",
    "versions": {
      "cuv": "又要谨慎，恐怕有人失了神的恩；恐怕有毒根生出来扰乱你们，因此叫众人沾染污秽。",
      "ccb": "（当代译本待补充）",
      "esv": "(ESV translation to be added)"
    }
  }
}