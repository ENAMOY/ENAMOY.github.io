  "b90f43df": {
    "id": "b90f43df",
    "ref": "罗马书1:1-4",
    "versions": {
      "cuv": "耶稣基督的仆人保罗，奉召为使徒，特派传神的福音。这福音是神从前藉众先知在圣经上所应许的，论到他儿子我主耶稣基督，按肉体说，是从大卫后裔生的；按圣善的灵说，因从死里复活，以大能显明是神的儿子。",
      "ccb": "（暂无当代译本）",
      "esv": "(ESV not available)"
    }
  },
  "a8ad3f37": {
    "id": "a8ad3f37",
    "ref": "路加福音24:46-49",
    "versions": {
      "cuv": "又对他们说：“照经上所写的，基督必受害，第三日从死里复活，并且人要奉他的名传悔改、赦罪的道，从耶路撒冷起直传到万邦。你们就是这些事的见证。我要将我父所应许的降在你们身上，你们要在城里等候，直到你们领受从上头来的能力。”",
      "ccb": "（暂无当代译本）",
      "esv": "(ESV not available)"
    }
  },
  "ee10a5d7": {
    "id": "ee10a5d7",
    "ref": "罗马书6:9",
    "versions": {
      "cuv": "因为知道基督既从死里复活，就不再死，死也不再作他的主了。",
      "ccb": "（暂无当代译本）",
      "esv": "(ESV not available)"
    }
  },
  "664d0f94": {
    "id": "664d0f94",
    "ref": "哥林多前书15:20",
    "versions": {
      "cuv": "但基督已经从死里复活，成为睡了之人初熟的果子。",
      "ccb": "（暂无当代译本）",
      "esv": "(ESV not available)"
    }
  },
