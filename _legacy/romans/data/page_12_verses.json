  "92e3c512": {
    "id": "92e3c512",
    "ref": "罗马书1:1-4",
    "versions": {
      "cuv": "耶稣基督的仆人保罗，奉召为使徒，特派传神的福音。这福音是神从前藉众先知在圣经上所应许的。论到他儿子我主耶稣基督，按肉体说，是从大卫后裔生的；按圣善的灵说，因从死里复活，以大能显明是神的儿子。",
      "ccb": "（暂无当代译本）",
      "esv": "(ESV not available)"
    }
  },
  "0ad11859": {
    "id": "0ad11859",
    "ref": "歌罗西书2:6-7",
    "versions": {
      "cuv": "你们既然接受了主基督耶稣，就当遵他而行；在他里面生根建造，信心坚固，正如你们所领的教训，感谢的心也更增长了。",
      "ccb": "（暂无当代译本）",
      "esv": "(ESV not available)"
    }
  },
  "f5a39010": {
    "id": "f5a39010",
    "ref": "罗马书1:5",
    "versions": {
      "cuv": "我们从他受了恩惠并使徒的职分，在万国之中叫人为他的名信服真道；",
      "ccb": "（暂无当代译本）",
      "esv": "(ESV not available)"
    }
  },
