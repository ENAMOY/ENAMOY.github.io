{
  "a6b4e9c2": {
    "id": "a6b4e9c2",
    "ref": "罗马书1:18",
    "versions": {
      "cuv": "原来，神的忿怒从天上显明在一切不虔不义的人身上，就是那些行不义阻挡真理的人。",
      "ccb": "（暂无当代译本）",
      "esv": "(ESV not available)"
    }
  },
  "fbd55968": {
    "id": "fbd55968",
    "ref": "彼得后书2:4-6",
    "versions": {
      "cuv": "就是天使犯了罪，神也没有宽容，曾把他们丢在地狱，交在黑暗坑中，等候审判。神也没有宽容上古的世代，曾叫洪水临到那不敬虔的世代，却保护了传义道的挪亚一家八口。又判定所多玛、蛾摩拉，将二城倾覆，焚烧成灰，作为后世不敬虔人的鉴戒；",
      "ccb": "（暂无当代译本）",
      "esv": "(ESV not available)"
    }
  },
  "d26a9fbd": {
    "id": "d26a9fbd",
    "ref": "罗马书2:5-6",
    "versions": {
      "cuv": "你竟任着你刚硬不悔改的心，为自己积蓄忿怒，以致神震怒，显他公义审判的日子来到。他必照各人的行为报应各人。",
      "ccb": "（暂无当代译本）",
      "esv": "(ESV not available)"
    }
  },
  "58470b73": {
    "id": "58470b73",
    "ref": "罗马书2:8",
    "versions": {
      "cuv": "惟有结党、不顺从真理、反顺从不义的，就以忿怒、恼恨报应他们；",
      "ccb": "（暂无当代译本）",
      "esv": "(ESV not available)"
    }
  },
  "c2b14b40": {
    "id": "c2b14b40",
    "ref": "罗马书3:5",
    "versions": {
      "cuv": "我且照着人的常话说，我们的不义若显出神的义来，我们可以怎么说呢？神降怒，是他不义吗？",
      "ccb": "（暂无当代译本）",
      "esv": "(ESV not available)"
    }
  },
  "c9952244": {
    "id": "c9952244",
    "ref": "罗马书4:15",
    "versions": {
      "cuv": "因为律法是惹动忿怒的(或译：叫人受刑的)；哪里没有律法，那里就没有过犯。",
      "ccb": "（暂无当代译本）",
      "esv": "(ESV not available)"
    }
  },
  "92b8a8dc": {
    "id": "92b8a8dc",
    "ref": "罗马书5:9",
    "versions": {
      "cuv": "现在我们既靠着他的血称义，就更要藉着他免去神的忿怒。",
      "ccb": "（暂无当代译本）",
      "esv": "(ESV not available)"
    }
  },
  "3eaa95b7": {
    "id": "3eaa95b7",
    "ref": "罗马书9:22-23",
    "versions": {
      "cuv": "倘若神要显明他的忿怒，彰显他的权能，就多多忍耐宽容那可怒、预备遭毁灭的器皿，又要将他丰盛的荣耀彰显在那蒙怜悯、早预备得荣耀的器皿上。",
      "ccb": "（暂无当代译本）",
      "esv": "(ESV not available)"
    }
  },
  "57ce92d7": {
    "id": "57ce92d7",
    "ref": "罗马书12:19",
    "versions": {
      "cuv": "亲爱的弟兄，不要自己伸冤，宁可让步，听凭主怒(或译：让人发怒)；因为经上记着：“主说：‘伸冤在我，我必报应。’”",
      "ccb": "（暂无当代译本）",
      "esv": "(ESV not available)"
    }
  },
  "a22261e0": {
    "id": "a22261e0",
    "ref": "罗马书13:4-5",
    "versions": {
      "cuv": "因为他是神的用人，是与你有益的。你若作恶，却当惧怕，因为他不是空空地佩剑；他是神的用人，是伸冤的，刑罚那作恶的。所以，你们必须顺服，不但是因为刑罚，也是因为良心。",
      "ccb": "（暂无当代译本）",
      "esv": "(ESV not available)"
    }
  }
}